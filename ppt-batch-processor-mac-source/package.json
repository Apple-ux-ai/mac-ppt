{
  "name": "ppt-batch-processor",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop toolbox for batch PPT processing",
  "homepage": "https://example.com/ppt-batch-processor",
  "author": {
    "name": "PPT Batch Processor Team",
    "email": "support@example.com"
  },
  "type": "module",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --config vite.config.browser.ts",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:10037 -t 60000 --delay 2000 && electron .\"",
    "build": "vue-tsc -b && vite build && electron-builder",
    "build:linux": "vue-tsc -b && vite build && electron-builder --linux AppImage deb",
    "build:dir": "vue-tsc -b && vite build && electron-builder --dir",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "archiver": "^7.0.1",
    "canvas": "^3.2.1",
    "csv-parser": "^3.2.0",
    "element-plus": "^2.13.1",
    "officecrypto-tool": "^0.0.19",
    "p-limit": "^6.1.0",
    "pdfjs-dist": "^5.4.530",
    "pinia": "^2.2.8",
    "pizzip": "^3.1.7",
    "pptxgenjs": "^4.0.1",
    "sharp": "^0.33.5",
    "vue": "^3.5.24",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/ui": "^3.0.5",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "fast-check": "^3.22.0",
    "prettier": "^3.4.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.0.5",
    "vue-tsc": "^3.1.4",
    "wait-on": "^8.0.1"
  }
}
